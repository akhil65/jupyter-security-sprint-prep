          {
            "id": "CKV_K8S_25",
            "severity": "CRITICAL",
            "description": "Docker socket mounted — full container escape to host",
            "resource": "jupyter/Deployment/jupyterhub",
            "remediation": "Remove volumes[1] hostPath /var/run/docker.sock"
          },
          {
            "id": "CKV_K8S_41",
            "severity": "CRITICAL",
            "description": "cluster-admin ClusterRoleBinding for jupyterhub SA",
            "resource": "jupyter/ClusterRoleBinding/jupyterhub-admin",
            "remediation": "Replace with minimal Role scoped to pod CRUD in jupyter namespace"
          },
          {
            "id": "CKV_K8S_49",
            "severity": "CRITICAL",
            "description": "Wildcard (*/*) permissions in ClusterRole",
            "resource": "jupyter/ClusterRoleBinding/jupyterhub-admin",
            "remediation": "Define explicit verbs: [get, list, create, delete, watch] on specific resources"
          },
          {
            "id": "CKV_K8S_35",
            "severity": "HIGH",
            "description": "Hardcoded secrets in env vars (JUPYTERHUB_CRYPT_KEY, POSTGRES_PASSWORD)",
            "resource": "jupyter/Deployment/jupyterhub",
            "remediation": "Use secretKeyRef pointing to K8s Secret; back with Vault or AWS Secrets Manager"
          },
          {
            "id": "CKV_K8S_6",
            "severity": "HIGH",
            "description": "Container runs as root (runAsNonRoot: false)",
            "resource": "jupyter/Deployment/jupyterhub, jupyter/Pod/jupyter-vulnerable-example",
            "remediation": "Set securityContext.runAsNonRoot: true, runAsUser: 1000"
          },
          {
            "id": "CKV_K8S_20",
            "severity": "HIGH",
            "description": "allowPrivilegeEscalation: true",
            "resource": "jupyter/Deployment/jupyterhub",
            "remediation": "Set allowPrivilegeEscalation: false"
          },
          {
            "id": "CKV_K8S_36",
            "severity": "MEDIUM",
            "description": "capabilities.add: [NET_ADMIN] — network admin capability",
            "resource": "jupyter/Deployment/jupyterhub",
            "remediation": "capabilities.drop: [ALL]; add back only what's strictly necessary"
          },
          {
            "id": "CKV_K8S_10_11_12_13",
            "severity": "MEDIUM",
            "description": "No CPU/memory requests or limits on any container",
            "resource": "all containers",
            "remediation": "Set resources.requests and resources.limits for CPU and memory"
          },
          {
            "id": "CKV_K8S_14",
            "severity": "MEDIUM",
            "description": "Unpinned :latest image tags",
            "resource": "hub, proxy, user pod",
            "remediation": "Pin to specific version tags (e.g. jupyterhub:5.3.0)"
          },
          {
            "id": "CKV_K8S_41_sa_token",
            "severity": "MEDIUM",
            "description": "automountServiceAccountToken: true on user pod",
            "resource": "jupyter/Pod/jupyter-vulnerable-example",
            "remediation": "Set automountServiceAccountToken: false"
          },
          {
            "id": "CKV_K8S_22",
            "severity": "LOW",
            "description": "readOnlyRootFilesystem: false",
            "resource": "hub, proxy, user pod",
            "remediation": "Set readOnlyRootFilesystem: true; add emptyDir mounts for writable paths"
          }
        ]
